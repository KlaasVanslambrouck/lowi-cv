# Kopieer dit bestand naar .env.local en vul de waarden in.
#
# Supabase wordt gebruikt voor beheer-login en portfolio_analytics.
# NEXT_PUBLIC_NIDUS_API_URL wijst naar nidus-api voor de Jarvis Q&A-widget
# koppeling met een publieke read-only endpoint.
#
# LET OP: client-side code mag enkel NEXT_PUBLIC_* variabelen gebruiken.
# SUPABASE_SERVICE_ROLE_KEY is server-only: nooit NEXT_PUBLIC_ prefix,
# nooit importeren in client components, enkel gebruiken in app/api/*/route.ts.
# ENABLE_HSTS is alleen nodig buiten Vercel production, en alleen achter HTTPS.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_NIDUS_API_URL=
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_HSTS=
